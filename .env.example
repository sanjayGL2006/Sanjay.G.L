# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Sheets Configuration
# Create a Service Account in Google Cloud Console, enable Sheets API, 
# and share your sheet with the service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-spreadsheet-id"

# Admin Authentication
# Generate a hash for your password using bcrypt (e.g., $2a$10$...)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2a$10$vI8meJd1YI1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X1X" # Example hash for 'password'

# UPI Configuration
UPI_ID="temple@upi"
TEMPLE_NAME="Sri Mariyamma Temple"
TEMPLE_ADDRESS="WHX7+3H2, Medarkeri, 3rd Cross Rd, Vinobha Nagar, Shivamogga, Karnataka 577204"
LOGO_URL="https://picsum.photos/seed/temple-logo/200/200"
